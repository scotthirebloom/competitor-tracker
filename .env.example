# -------------------------------------------------------------------
# competitor_tracker — environment variables
# Copy this file to .env and fill in your values.
# The .env file is gitignored and should never be committed.
# -------------------------------------------------------------------

# Required: Google Gemini API key (used for AI summaries)
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Required: Slack incoming webhook URL (used to post the weekly digest)
# Create one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Optional: LinkedIn credentials for automatic session re-login.
# If set, the tracker will attempt to re-authenticate when the saved
# session expires, without requiring manual intervention.
# Set BOTH or leave BOTH unset.
LINKEDIN_USERNAME=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password_here

# Optional: API Direct key for Twitter, Facebook, and Reddit fallback.
# Sign up at: https://apidirect.io
# If unset, Twitter/Facebook scraping and Reddit fallback are disabled.
APIDIRECT_API_KEY=your_apidirect_api_key_here

# Optional: Override the default monthly request limit per endpoint (default: 50).
# APIDIRECT_MONTHLY_LIMIT=50
